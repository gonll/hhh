# En XAMPP Windows, si falla "Host localhost is not allowed", usar 127.0.0.1
DB_HOST=127.0.0.1
DB_USER=root
DB_PASS=tu_clave
DB_NAME=nombre_de_la_base

# Deploy: en LOCAL poner ENVIRONMENT=dev para ver la barra "Subir código / Subir base" en index.php
ENVIRONMENT=dev
# Mismo UUID en .env del servidor (secreto compartido)
DEPLOY_UUID=cambiar-por-un-uuid-largo-aleatorio
# URL del script que recibe el dump (en producción debe existir sync/sync_db.php)
DEPLOY_URL=https://tudominio.com/ruta-al-proyecto/sync/sync_db.php
# Opcional: si difiere de DEPLOY_URL con sync_git.php en lugar de sync_db.php
# DEPLOY_URL_GIT=https://tudominio.com/ruta-al-proyecto/sync/sync_git.php

# El correo (expensas, PDF liq prod, etc.) usa mail_config.php en la raíz del proyecto, no .env
